# Agentic Operations Control Plane Configuration
# Copy to .env and fill in actual values

# Database
COMPOSE_PROJECT_NAME=soc-dashboard
DASHBOARD_PORT=25480
DASHBOARD_BIND=127.0.0.1
DASHBOARD_HTTPS_PORT=25443
DASHBOARD_HTTPS_BIND=0.0.0.0
DASHBOARD_TLS_DIR=./runtime/tls
DASHBOARD_TLS_COMMON_NAME=agentic-operations.local
DASHBOARD_TLS_DAYS=825
SOC_DB_PORT=5433
SOC_DB_BIND=127.0.0.1
SOC_DB_USER=<vault:soc-dashboard-db-user>
SOC_DB_PASSWORD=<vault:soc-dashboard-db-password>
AGENT_MEMORY_DB_BIND=127.0.0.1

# iTop Connection
# Set ITOP_SYNC_ENABLED=false for local-only or non-iTop deployments.
ITOP_SYNC_ENABLED=true
ITOP_HOST=<itop-host-or-ip>
ITOP_PORT=25432
ITOP_WEB_BASE=http://<itop-host-or-ip>:25432
ITOP_USER=<vault:itop-api-user>
ITOP_PASSWORD=<vault:itop-api-password>
ITOP_SECURITY_TEAM_ID=65
ITOP_DEFAULT_ORG_ID=<optional-itop-org-id-for-outbound-create>
ITOP_DEFAULT_CALLER_ID=<optional-itop-caller-id-for-outbound-create>

# Optional external ticketing providers. Leave blank to fail closed.
SERVICENOW_INSTANCE_URL=
SERVICENOW_TOKEN=<vault:servicenow-token>
SERVICENOW_USER=
SERVICENOW_PASSWORD=<vault:servicenow-password>
SERVICENOW_ASSIGNMENT_GROUP=
SERVICENOW_REQUEST_TABLE=sc_request
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=<vault:jira-api-token>
JIRA_PROJECT_KEY=
JIRA_ISSUE_TYPE=Task
GENERIC_TICKETING_WEBHOOK_URL=
GENERIC_TICKETING_WEBHOOK_TOKEN=<vault:generic-ticketing-webhook-token>
GENERIC_TICKETING_DRY_RUN=false

# Optional Wazuh gated provider evidence. Store values in the deployment vault
# or injected environment, never in source.
WAZUH_API_URL=
WAZUH_API_USER=
WAZUH_API_PASSWORD=<vault:wazuh-api-password>
WAZUH_INDEXER_URL=
WAZUH_INDEXER_USER=
WAZUH_INDEXER_PASSWORD=<vault:wazuh-indexer-password>
WAZUH_VERIFY_TLS=false

# Sync Intervals (seconds)
ITOP_DISCOVERY_INTERVAL=2
ITOP_FULL_SYNC_INTERVAL=60
HEALTH_CHECK_INTERVAL=60
MAX_CONCURRENT_AGENTS=1
AGENT_TIMEOUT_MINUTES=0
AGENT_NO_OUTPUT_STALL_SECONDS=3600
AGENT_TRANSIENT_MODEL_RETRY_MAX=3
AGENT_TRANSIENT_MODEL_RETRY_DELAY_SECONDS=30
AGENT_CURL_ALLOWED_HOSTS=localhost,127.0.0.1,::1,host.docker.internal,ai-proxy,192.168.50.222,api.openai.com,api.anthropic.com,inference-api.nousresearch.com,virustotal.com,*.virustotal.com,urlscan.io,*.urlscan.io,hybrid-analysis.com,*.hybrid-analysis.com
AUTO_ASSIGNMENT_MAX_ACTIVE_PER_RULE=1
AGENT_AUDITOR_AUTO_RECOVER=false
AGENT_HARNESS=hermes
# Model routing posture:
#   local    = local/on-prem first; external providers disabled unless explicit
#   external = lab/demo/test route through configured external provider
# Flip for demos with: python scripts/switch_model_route.py --route local --restart
AI_MODEL_ROUTE=local
AI_PROXY_MODEL_ROUTE=local
AI_PROXY_EXTERNAL_ENABLED=false
AI_PROXY_LOCAL_MODEL=qwen/qwen3.6-27b
AI_PROXY_EXTERNAL_PROVIDER=nous
AI_PROXY_EXTERNAL_MODEL=deepseek/deepseek-v4-flash
AI_PROXY_LOCAL_ALIASES=default,agent-default,local/agent-default,deepseek/deepseek-v4-flash,deepseek-v4-flash
AI_PROXY_EXTERNAL_ALIASES=external/agent-default
AI_PROXY_EXTERNAL_FALLBACK_PROVIDERS=openrouter,lmstudio
LMSTUDIO_FALLBACK_PROVIDERS=
NOUS_FALLBACK_PROVIDERS=openrouter,lmstudio
OPENROUTER_FALLBACK_PROVIDERS=lmstudio
OPENAI_FALLBACK_PROVIDERS=
CUSTOM_FALLBACK_PROVIDERS=
AGENT_DEFAULT_MODEL=local/agent-default
AGENT_TRANSIENT_MODEL_RETRY_MAX=3
AGENT_TRANSIENT_MODEL_RETRY_DELAY_SECONDS=30
AGENT_TRANSIENT_MODEL_FALLBACK_ENABLED=false
AGENT_TRANSIENT_MODEL_FALLBACK_MODEL=local/agent-default
AGENT_PERMISSION_MODE=acceptEdits
AGENT_ALLOWED_TOOLS=Read,Write,Bash(curl *),Bash(node *),Bash(npx *),Bash(playwright *)
AGENT_LLM_BASE_URL=http://ai-proxy:4001
AGENT_LLM_AUTH_TOKEN=
AI_PROXY_PORT=4001
AI_PROXY_BIND=127.0.0.1
PROXY_CONFIG_PATH=./runtime/proxy_config.json
LM_STUDIO_BASE=http://host.docker.internal:1234
LM_STUDIO_TOKEN=lmstudio
ANTHROPIC_BASE=https://api.anthropic.com
NOUS_BASE=https://inference-api.nousresearch.com/v1
NOUS_API_KEY=
OPENROUTER_BASE=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL_ALIASES=openrouter/free,deepseek/deepseek-v4-flash:free
OPENROUTER_HTTP_REFERER=http://agentic-operations.local
OPENROUTER_APP_TITLE=Agentic Operations
HERMES_BIN=/home/cereal/.hermes/hermes-agent/venv/bin/hermes
HERMES_HOME=/home/cereal/.hermes
HERMES_HOME_DIR=./runtime/hermes
HERMES_UV_PYTHON_DIR=./runtime/hermes-uv-python
HERMES_DEFAULT_PROVIDER=dashboard-proxy
HERMES_LOCAL_PROVIDER=dashboard-proxy
HERMES_TOOLSETS=terminal,file
HERMES_MAX_TURNS=90
HERMES_RUN_AS_UID=1000
HERMES_RUN_AS_GID=1000
CLAUDE_CREDENTIALS_FILE=./runtime/empty_credentials.json
CLAUDE_SETTINGS_FILE=./runtime/claude_settings.json
GITLAB_BASE_URL=
DASHBOARD_API_BASE=http://localhost:8000
DASHBOARD_AUTH_MODE=header
DASHBOARD_AUTH_ENFORCEMENT=enforce
DASHBOARD_TRUSTED_AUTH_SECRET=<vault:dashboard-trusted-auth-secret>
DASHBOARD_SERVICE_TOKEN=<vault:dashboard-service-token>
DASHBOARD_SESSION_SECRET=<vault:dashboard-session-secret>
DASHBOARD_SESSION_TTL_SECONDS=3600
DASHBOARD_COOKIE_SECURE=true
DASHBOARD_PROTECT_UI=true
DASHBOARD_PUBLIC_HEALTH=false
DASHBOARD_CORS_ORIGINS=
DASHBOARD_HSTS=true
TRACK_INTERVAL=10
STUCK_TIMEOUT_MINUTES=60

# Optional host skill mounts for setup inventory and agent context.
# Point these at the harness skill directories in the deployment environment.
CLAUDE_SKILLS_DIR=./reference_skills
AGENTS_SKILLS_DIR=./reference_skills
