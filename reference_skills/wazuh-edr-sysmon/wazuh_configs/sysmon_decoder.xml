<!-- ============================================================
     Wazuh Sysmon Log Decoders
     Handles: Windows Sysmon event channel + SysmonForLinux JSON
     Compatible: Wazuh v4.14.x
     ============================================================ -->

<!-- Windows Sysmon Event Channel Decoder -->
<decoder name="sysmon">
  <prematch>Microsoft-Windows-Sysmon/Operational</prematch>
</decoder>

<!-- Sysmon Event ID extraction -->
<decoder name="sysmon-event">
  <parent>sysmon</parent>
  <regex type="xfwlog">^.*\sEventID\s*:\s*(\d+)</regex>
  <order>EventID</order>
</decoder>

<!-- Sysmon Process Creation Fields (EventID 1) -->
<decoder name="sysmon-process-create">
  <parent>sysmon</parent>
  <regex type="xfwlog">^.*\sRuleName\s*:\s*(\S+)</regex>
  <order>RuleName</order>
  <regex type="xfwlog">^.*\sUtcTime\s*:\s*(\S+)</regex>
  <order>UtcTime</order>
  <regex type="xfwlog">^.*\sProcessGuid\s*:\s*(\S+)</regex>
  <order>ProcessGuid</order>
  <regex type="xfwlog">^.*\sProcessId\s*:\s*(\d+)</regex>
  <order>ProcessId</order>
  <regex type="xfwlog">^.*\sImage\s*:\s*(\S+)</regex>
  <order>Image</order>
  <regex type="xfwlog">^.*\sFileVersion\s*:\s*(\S+)</regex>
  <order>FileVersion</order>
  <regex type="xfwlog">^.*\sDescription\s*:\s*(\S+)</regex>
  <order>Description</order>
  <regex type="xfwlog">^.*\sProduct\s*:\s*(\S+)</regex>
  <order>Product</order>
  <regex type="xfwlog">^.*\sCompany\s*:\s*(\S+)</regex>
  <order>Company</order>
  <regex type="xfwlog">^.*\sOriginalFileName\s*:\s*(\S+)</regex>
  <order>OriginalFileName</order>
  <regex type="xfwlog">^.*\sDirectory\s*:\s*(\S+)</regex>
  <order>Directory</order>
  <regex type="xfwlog">^.*\sCommandLine\s*:\s*(.+)$</regex>
  <order>CommandLine</order>
  <regex type="xfwlog">^.*\sUser\s*:\s*(\S+)</regex>
  <order>User</order>
  <regex type="xfwlog">^.*\sLogonGuid\s*:\s*(\S+)</regex>
  <order>LogonGuid</order>
  <regex type="xfwlog">^.*\sLogonId\s*:\s*(\S+)</regex>
  <order>LogonId</order>
  <regex type="xfwlog">^.*\sCurrentDirectory\s*:\s*(\S+)</regex>
  <order>CurrentDirectory</order>
  <regex type="xfwlog">^.*\sHashes\s*:\s*(\S+)</regex>
  <order>Hashes</order>
  <regex type="xfwlog">^.*\sParentProcessGuid\s*:\s*(\S+)</regex>
  <order>ParentProcessGuid</order>
  <regex type="xfwlog">^.*\sParentProcessId\s*:\s*(\d+)</regex>
  <order>ParentProcessId</order>
  <regex type="xfwlog">^.*\sParentImage\s*:\s*(\S+)</regex>
  <order>ParentImage</order>
  <regex type="xfwlog">^.*\sParentCommandLine\s*:\s*(.+)$</regex>
  <order>ParentCommandLine</order>
</decoder>

<!-- Sysmon Network Connection Fields (EventID 3) -->
<decoder name="sysmon-network">
  <parent>sysmon</parent>
  <regex type="xfwlog">^.*\sImage\s*:\s*(\S+)</regex>
  <order>Image</order>
  <regex type="xfwlog">^.*\sUser\s*:\s*(\S+)</regex>
  <order>User</order>
  <regex type="xfwlog">^.*\sProtocol\s*:\s*(\S+)</regex>
  <order>Protocol</order>
  <regex type="xfwlog">^.*\sSourceIsListener\s*:\s*(\S+)</regex>
  <order>SourceIsListener</order>
  <regex type="xfwlog">^.*\sSourceIp\s*:\s*(\S+)</regex>
  <order>SourceIp</order>
  <regex type="xfwlog">^.*\sSourcePort\s*:\s*(\d+)</regex>
  <order>SourcePort</order>
  <regex type="xfwlog">^.*\sSourceHostname\s*:\s*(\S+)</regex>
  <order>SourceHostname</order>
  <regex type="xfwlog">^.*\sDestinationIp\s*:\s*(\S+)</regex>
  <order>DestinationIp</order>
  <regex type="xfwlog">^.*\sDestinationPort\s*:\s*(\d+)</regex>
  <order>DestinationPort</order>
  <regex type="xfwlog">^.*\sDestinationHostname\s*:\s*(\S+)</regex>
  <order>DestinationHostname</order>
</decoder>

<!-- Sysmon File Creation Fields (EventID 11) -->
<decoder name="sysmon-file">
  <parent>sysmon</parent>
  <regex type="xfwlog">^.*\sImage\s*:\s*(\S+)</regex>
  <order>Image</order>
  <regex type="xfwlog">^.*\sTargetFilename\s*:\s*(\S+)</regex>
  <order>TargetFilename</order>
  <regex type="xfwlog">^.*\sCreationUtcTime\s*:\s*(\S+)</regex>
  <order>CreationUtcTime</order>
  <regex type="xfwlog">^.*\sHashes\s*:\s*(\S+)</regex>
  <order>Hashes</order>
</decoder>

<!-- Sysmon Registry Event Fields (EventID 12-14) -->
<decoder name="sysmon-registry">
  <parent>sysmon</parent>
  <regex type="xfwlog">^.*\sImage\s*:\s*(\S+)</regex>
  <order>Image</order>
  <regex type="xfwlog">^.*\sTargetObject\s*:\s*(.+)$</regex>
  <order>TargetObject</order>
  <regex type="xfwlog">^.*\sType\s*:\s*(\S+)</regex>
  <order>Type</order>
  <regex type="xfwlog">^.*\sNewValue\s*:\s*(.+)$</regex>
  <order>NewValue</order>
</decoder>

<!-- Sysmon Process Access Fields (EventID 10) -->
<decoder name="sysmon-process-access">
  <parent>sysmon</parent>
  <regex type="xfwlog">^.*\sSourceImage\s*:\s*(\S+)</regex>
  <order>SourceImage</order>
  <regex type="xfwlog">^.*\sTargetImage\s*:\s*(\S+)</regex>
  <order>TargetImage</order>
  <regex type="xfwlog">^.*\sSourceProcessId\s*:\s*(\d+)</regex>
  <order>SourceProcessId</order>
  <regex type="xfwlog">^.*\sTargetProcessId\s*:\s*(\d+)</regex>
  <order>TargetProcessId</order>
  <regex type="xfwlog">^.*\sGrantedAccess\s*:\s*(\S+)</regex>
  <order>GrantedAccess</order>
  <regex type="xfwlog">^.*\sCallTrace\s*:\s*(.+)$</regex>
  <order>CallTrace</order>
</decoder>

<!-- SysmonForLinux JSON Decoder -->
<decoder name="sysmon_linux">
  <parent>json</parent>
  <regex>^.*"event_type"\s*:\s*"(ProcessCreate|NetworkConnect|FileCreate|DriverLoad|RawAccessRead|ProcessTerminate)".*$</regex>
  <variable>event_type</variable>
  <position>after_first</position>
</decoder>

<!-- SysmonForLinux Process Create -->
<decoder name="sysmon_linux_process">
  <parent>sysmon_linux</parent>
  <regex>^.*"process_create_event"\s*:\s*\{</regex>
  <variable>parser</variable>
  <position>after_first</position>
</decoder>

<!-- SysmonForLinux Network Connect -->
<decoder name="sysmon_linux_network">
  <parent>sysmon_linux</parent>
  <regex>^.*"network_connection_event"\s*:\s*\{</regex>
  <variable>parser</variable>
  <position>after_first</position>
</decoder>
