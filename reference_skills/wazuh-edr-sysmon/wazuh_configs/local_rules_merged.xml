<!-- Wazuh Custom Rules: Mailcow + Sysmon/EDR -->
<!-- Mailcow: 100100-100108 | Sysmon: 100200-100299 -->

<group name="mailcow,siem">

  <!-- Base rule for all Mailcow CEF syslog events -->
  <rule id="100100" level="0">
    <match>CEF:0|Mailcow|</match>
    <description>Mailcow: event received</description>
    <group>mailcow</group>
  </rule>

  <!-- Phishing report alert -->
  <rule id="100101" level="12">
    <if_sid>100100</if_sid>
    <match>phishing_report</match>
    <description>Mailcow: Phishing email report submitted</description>
    <group>mailcow,phishing</group>
  </rule>

  <!-- LMTP delivery success -->
  <rule id="100102" level="3">
    <if_sid>100100</if_sid>
    <match>delivery_success</match>
    <description>Mailcow: Email delivered to mailbox via LMTP</description>
    <group>mailcow,delivery</group>
  </rule>

  <!-- LMTP delivery failure -->
  <rule id="100103" level="8">
    <if_sid>100100</if_sid>
    <match>delivery_failure</match>
    <description>Mailcow: Email delivery failed via LMTP</description>
    <group>mailcow,delivery,failure</group>
  </rule>

  <!-- Authentication success -->
  <rule id="100104" level="2">
    <if_sid>100100</if_sid>
    <match>auth_success</match>
    <description>Mailcow: User authentication successful</description>
    <group>mailcow,auth</group>
  </rule>

  <!-- Authentication failure -->
  <rule id="100105" level="10">
    <if_sid>100100</if_sid>
    <match>auth_failure</match>
    <description>Mailcow: User authentication failed</description>
    <group>mailcow,auth,failure</group>
  </rule>

  <!-- SMTP connection -->
  <rule id="100106" level="3">
    <if_sid>100100</if_sid>
    <match>smtp_connection</match>
    <description>Mailcow: SMTP connection received</description>
    <group>mailcow,smtp</group>
  </rule>

  <!-- Generic Mailcow log events (non-CEF format) -->
  <rule id="100107" level="5">
    <match>mailcow-fwd</match>
    <description>Mailcow: log event via forwarder</description>
    <group>mailcow</group>
  </rule>

  <!-- report-phish logger events -->
  <rule id="100108" level="7">
    <match>report-phish</match>
    <description>Mailcow: Report-Phish alert event</description>
    <group>mailcow,phishing</group>
  </rule>

</group>

<group name="sysmon,edr">

  <!-- LOLBin process execution -->
  <rule id="100201" level="10">
    <match>Linux-Sysmon</match>
    <match>EventID.*1</match>
    <match>Image.*(certutil|bits|mshta|regsvr32|rundll32|cscript|wscript|esentutl|forfiles|makecab|msiexec|ntdsutil|pnputil|regasm|regedit|sc).(exe|dll|bat|cmd)</match>
    <description>Sysmon: Suspicious LOLBin process execution detected</description>
    <group>sysmon,process_creation,mitre_t1202,mitre_t1218</group>
  </rule>

  <!-- Suspicious PowerShell -->
  <rule id="100202" level="10">
    <match>Linux-Sysmon</match>
    <match>EventID.*1</match>
    <match>Image.*powershell.(exe|dll)</match>
    <match>CommandLine.*-(enc|encodedcommand|nop|w hidden)</match>
    <description>Sysmon: Suspicious PowerShell execution encoded/hidden</description>
    <group>sysmon,process_creation,mitre_t1059</group>
  </rule>

  <!-- Recon/credential dumping in cmd -->
  <rule id="100203" level="8">
    <match>Linux-Sysmon</match>
    <match>EventID.*1</match>
    <match>Image.*cmd.exe</match>
    <match>CommandLine.*(whoami|ipconfig|net user|net group|netstat|tasklist|systeminfo|wmic|procdump|mimikatz|lazagne|sekurlsa)</match>
    <description>Sysmon: Reconnaissance or credential dumping command in cmd</description>
    <group>sysmon,process_creation,mitre_t1003,mitre_t1018</group>
  </rule>

  <!-- Known credential dumping tools -->
  <rule id="100213" level="15">
    <match>Linux-Sysmon</match>
    <match>EventID.*1</match>
    <match>Image.*(mimikatz|procdump|lazagne|pwdump|dumpert|nanodump|cerberus|sharpdump).(exe|dll|ps1|py)</match>
    <description>Sysmon: Known credential dumping tool execution</description>
    <group>sysmon,process_creation,mitre_t1003</group>
  </rule>

  <!-- LSASS access -->
  <rule id="100204" level="12">
    <match>Linux-Sysmon</match>
    <match>EventID.*10</match>
    <match>TargetImage.*lsass.exe</match>
    <description>Sysmon: Process access to LSASS potential credential dumping</description>
    <group>sysmon,process_access,mitre_t1003</group>
  </rule>

  <!-- Network from suspicious binary -->
  <rule id="100205" level="9">
    <match>Linux-Sysmon</match>
    <match>EventID.*3</match>
    <match>Image.*(certutil|bits|mshta|wget|curl|powershell|cmd).(exe|dll)</match>
    <description>Sysmon: Network connection from suspicious binary</description>
    <group>sysmon,network_connection,mitre_t1105</group>
  </rule>

  <!-- Suspicious port connection -->
  <rule id="100206" level="10">
    <match>Linux-Sysmon</match>
    <match>EventID.*3</match>
    <match>DestinationPort.*(4444|5555|6666|7777|8888|9999|1337|31337)</match>
    <description>Sysmon: Connection to suspicious port potential C2</description>
    <group>sysmon,network_connection,mitre_t1071</group>
  </rule>

  <!-- Suspicious file creation -->
  <rule id="100207" level="10">
    <match>Linux-Sysmon</match>
    <match>EventID.*11</match>
    <match>TargetFilename.*(Temp|AppData|Startup|System32|SysWOW64|Windows).(exe|dll|bat|cmd|ps1|vbs|scr)</match>
    <description>Sysmon: Suspicious file creation in system/temp directory</description>
    <group>sysmon,file_creation,mitre_t1036</group>
  </rule>

  <!-- Registry persistence -->
  <rule id="100208" level="12">
    <match>Linux-Sysmon</match>
    <match>EventID.*13</match>
    <match>TargetObject.*(Run|RunOnce|Services|Winlogon|Shell|Userinit|AppInit_DLLs)</match>
    <description>Sysmon: Registry persistence mechanism detected</description>
    <group>sysmon,registry_persistence,mitre_t1547</group>
  </rule>

  <!-- Process injection -->
  <rule id="100209" level="13">
    <match>Linux-Sysmon</match>
    <match>EventID.*8</match>
    <description>Sysmon: CreateRemoteThread process injection detected</description>
    <group>sysmon,process_injection,mitre_t1055</group>
  </rule>

  <!-- Raw disk access -->
  <rule id="100210" level="12">
    <match>Linux-Sysmon</match>
    <match>EventID.*9</match>
    <description>Sysmon: Raw disk access detected</description>
    <group>sysmon,raw_access,mitre_t1003</group>
  </rule>

  <!-- Driver loading -->
  <rule id="100211" level="8">
    <match>Linux-Sysmon</match>
    <match>EventID.*6</match>
    <description>Sysmon: Driver loaded</description>
    <group>sysmon,driver_load,mitre_t1546</group>
  </rule>

  <!-- DLL loading into legitimate process -->
  <rule id="100212" level="11">
    <match>Linux-Sysmon</match>
    <match>EventID.*7</match>
    <match>Image.*(explorer|svchost|chrome|firefox|outlook|winword|excel).(exe|dll)</match>
    <description>Sysmon: DLL loaded into legitimate process potential hijacking</description>
    <group>sysmon,image_load,mitre_t1574</group>
  </rule>

  <!-- Known credential dumping tools -->
  <rule id="100213" level="15">
    <match>Linux-Sysmon</match>
    <match>EventID.*1</match>
    <match>Image.*(mimikatz|procdump|lazagne|pwdump|dumpert|nanodump|cerberus|sharpdump)</match>
    <description>Sysmon: Known credential dumping tool execution</description>
    <group>sysmon,process_creation,mitre_t1003</group>
  </rule>

  <!-- WMI activity -->
  <rule id="100214" level="10">
    <match>Linux-Sysmon</match>
    <match>EventID.*(19|20|21)</match>
    <description>Sysmon: WMI event activity detected</description>
    <group>sysmon,wmi,mitre_t1047</group>
  </rule>

  <!-- LOTL binaries -->
  <rule id="100215" level="11">
    <match>Linux-Sysmon</match>
    <match>EventID.*1</match>
    <match>Image.*(msiexec|esentutl|forfiles|makecab|mc|ntdsutil|pnputil)</match>
    <description>Sysmon: Living-off-the-land binary execution</description>
    <group>sysmon,lotl,mitre_t1127</group>
  </rule>

  <!-- Defense evasion -->
  <rule id="100216" level="12">
    <match>Linux-Sysmon</match>
    <match>EventID.*1</match>
    <match>Image.*(wevtutil|cmd|powershell)</match>
    <match>CommandLine.*(clear-log|wevtutil cl|amsi|bypass|executionpolicy)</match>
    <description>Sysmon: Defense evasion technique log clearing or AMSI bypass</description>
    <group>sysmon,defense_evasion,mitre_t1070</group>
  </rule>

  <!-- SysmonForLinux: Suspicious process from temp -->
  <rule id="100221" level="10">
    <match>Linux-Sysmon</match>
    <match>(tmp|dev/shm|var/tmp)</match>
    <description>SysmonForLinux: Suspicious process execution from temp directory</description>
    <group>sysmon,linux,process_creation,mitre_t1036</group>
  </rule>

  <!-- SysmonForLinux: Suspicious port connection -->
  <rule id="100222" level="11">
    <match>Linux-Sysmon</match>
    <match>(Destination|Remote)</match>
    <match>(4444|5555|6666|7777|8888|9999|1337|31337)</match>
    <description>SysmonForLinux: Connection to suspicious port potential C2</description>
    <group>sysmon,linux,network_connection,mitre_t1071</group>
  </rule>

  <!-- SysmonForLinux: Security testing tools -->
  <rule id="100223" level="9">
    <match>Linux-Sysmon</match>
    <match>(nmap|nikto|sqlmap|metasploit|msfconsole|msfvenom|hydra|john|hashcat)</match>
    <description>SysmonForLinux: Security testing/exploitation tool execution</description>
    <group>sysmon,linux,process_creation,mitre_t1190</group>
  </rule>

  <!-- SysmonForLinux: Reverse shell -->
  <rule id="100224" level="12">
    <match>Linux-Sysmon</match>
    <match>(wget|curl)</match>
    <match>(bash|sh)</match>
    <description>SysmonForLinux: Reverse shell via download pipe execution</description>
    <group>sysmon,linux,process_creation,mitre_t1059</group>
  </rule>

  <!-- SysmonForLinux: Persistence file creation -->
  <rule id="100225" level="10">
    <match>Linux-Sysmon</match>
    <match>(/etc/cron|/etc/systemd|/etc/init.d|.bashrc|.profile|/etc/rc.local)</match>
    <description>SysmonForLinux: Persistence mechanism file creation</description>
    <group>sysmon,linux,file_creation,mitre_t1543</group>
  </rule>

  <!-- SysmonForLinux: Sensitive file access -->
  <rule id="100226" level="13">
    <match>Linux-Sysmon</match>
    <match>(passwd|shadow|sudoers|authorized_keys|sshd_config)</match>
    <description>SysmonForLinux: Sensitive system file access/modification</description>
    <group>sysmon,linux,process_creation,mitre_t1098</group>
  </rule>

  <!-- Sysmon base catch-all (level 0, fires if no higher rule matched) -->
  <rule id="100200" level="0">
    <match>Linux-Sysmon</match>
    <description>Sysmon: event received</description>
    <group>sysmon</group>
  </rule>

</group>
