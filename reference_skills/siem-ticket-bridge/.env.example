# ============================================================
# SIEM-Ticketing Bridge Configuration
# ============================================================
# Copy this file to .env and fill in actual values.
# NEVER commit .env with real credentials.
# ============================================================

# ---- Bridge Settings ----
BRIDGE_ENABLED=true
BRIDGE_POLL_INTERVAL=60
BRIDGE_BATCH_SIZE=50
BRIDGE_MAX_TICKETS_PER_POLL=10
BRIDGE_DEDUP_WINDOW=3600
BRIDGE_PROCESSED_RETENTION_SECONDS=86400
BRIDGE_MAX_PROCESSED_ALERTS=20000
BRIDGE_CORRELATION_WINDOW=300
BRIDGE_LOG_LEVEL=INFO
BRIDGE_LOG_FILE=/var/log/siem-ticket-bridge/bridge.log
BRIDGE_LOG_MAX_BYTES=10485760
BRIDGE_LOG_BACKUP_COUNT=5
BRIDGE_STATE_FILE=/var/lib/siem-ticket-bridge/state.json
BRIDGE_SEVERITY_MAP_FILE=severity_map.json
BRIDGE_SUPPRESSION_RULES_FILE=/etc/siem-ticket-bridge/suppression_rules.json

# ---- SIEM Configuration (Wazuh) ----
BRIDGE_SIEM_TYPE=wazuh
BRIDGE_SIEM_HOST=127.0.0.1
BRIDGE_SIEM_PORT=26500
BRIDGE_SIEM_API_USER=wazuh-wui
BRIDGE_SIEM_API_PASSWORD=
BRIDGE_SIEM_INDEXER_PORT=26920
BRIDGE_SIEM_INDEXER_USER=admin
BRIDGE_SIEM_INDEXER_PASSWORD=
BRIDGE_SIEM_SYSLOG_PORT=26514
BRIDGE_SIEM_SYSLOG_ENABLED=true
BRIDGE_SIEM_TIMEOUT=10
BRIDGE_SIEM_ALERT_INDEX=wazuh-alerts-4.x-*
BRIDGE_SIEM_CA_CERT_PATH=

# ---- SIEM Configuration (Splunk) ----
# BRIDGE_SIEM_TYPE=splunk
# BRIDGE_SIEM_HEC_ENDPOINT=https://localhost:8088/services/collector/event
# BRIDGE_SIEM_HEC_TOKEN=
# BRIDGE_SIEM_TIMEOUT=10

# ---- Ticketing Configuration (iTop) ----
BRIDGE_TICKETING_TYPE=itop
BRIDGE_TICKETING_HOST=127.0.0.1
BRIDGE_TICKETING_PORT=25432
BRIDGE_TICKETING_API_USER=admin
BRIDGE_TICKETING_API_PASSWORD=
BRIDGE_TICKETING_ORG_ID=1
BRIDGE_TICKETING_CALLER_ID=1
BRIDGE_TICKETING_TEAM_ID=
BRIDGE_TICKETING_TIMEOUT=10
BRIDGE_TICKETING_SCHEME=http
BRIDGE_TICKETING_API_PATH=/webservices/rest.php

