# Log Forwarder Configuration
# Each line: KEY=VALUE (loaded before environment variables)
# Environment variables override these defaults

# Wazuh SIEM target
WAZUH_HOST=127.0.0.1
WAZUH_PORT=26151

# Zeek log source
ZEEK_LOG_DIR=/opt/soc-testing/logs/zeek
ZEEK_ENABLED=true

# Suricata log source
SURICATA_LOG=/opt/soc-testing/logs/suricata/eve.json
SURICATA_ENABLED=true

# Forwarder behavior
POSITION_FILE=/tmp/forwarder_positions.json
POLL_INTERVAL=1
MAX_QUEUE=10000
RECONNECT_DELAY=5
